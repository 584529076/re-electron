{
  "id": "Flux2Klein9b_Undressing",
  "name": "Flux2Klein9b_Undressing",
  "description": "上传图片",
  "mode": "nsfw",
  "accepts": ["image"],
  "cover": "covers/Flux2Klein9b_Undressing.png",
  "coverFallback": {
    "icon": "fa-film",
    "gradient": ["#7c3aed", "#db2777"]
  },
  "workflowFile": "Flux2Klein9b_Undressing.json",
  "models": ["Kelin2"],
  "modelField": { "nodeId": "1", "field": "unet_name" },
  "formFields": [
    {
      "id": "start_image",
      "label": "图片",
      "type": "image",
      "nodeId": "16",
      "field": "image",
      "required": true,
      "accept": "image/*",
      "note": "支持 png/jpg/webp，上传后自动放到 ComfyUI 的 input 目录"
    },
    {
      "id": "loras",
      "label": "Lora 链（5 节点链式）",
      "type": "loraMulti",
      "nodeIds": ["59", "105", "60", "61", "28"],
      "weightFields": ["strength_model", "strength_model", "strength_model", "strength_model", "strength_model"],
      "field": "lora_name",
      "default": [],
      "group": "Lora 链",
      "filterByModel": true,
      "note": "按链顺序 59→105→60→61→28 写入；按主模型筛选"
    },
    {
      "id": "seed",
      "label": "Seed (K采样器)",
      "type": "number",
      "nodeId": "31",
      "field": "value",
      "default": -1,
      "randomizable": true,
      "min": -1,
      "max": 4294967295,
      "note": "实际写入 node 31 (PrimitiveInt)，通过链路传至 node 22 KSampler.seed；-1 = 每次随机（避免 ComfyUI 命中 prompt cache 复用旧结果）"
    }
  ],
  "outputNodes": [
    { "nodeId": "107", "type": "image", "filenamePrefix": "ComfyUI" }
  ]
}
