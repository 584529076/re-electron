{
  "id": "flux-2-klein（角度控制）",
  "name": "Flux-2 Klein 角度控制",
  "description": "Flux-2-Klein 9B 角度重渲：通过内置多角度 LoRA（Klein_9B-NSFW）改变相机视角（水平/垂直/缩放），主体内容保持不变",
  "mode": "nsfw",
  "accepts": ["image"],
  "coverFallback": {
    "icon": "fa-camera-rotate",
    "gradient": ["#7c3aed", "#db2777"]
  },
  "workflowFile": "flux-2-klein（角度控制）.json",
  "models": ["Flux-2-Klein-9B"],
  "formFields": [
    {
      "id": "image",
      "label": "上传图片",
      "type": "image",
      "nodeId": "63",
      "field": "image",
      "required": true,
      "accept": "image/*",
      "note": "支持 png/jpg/webp，上传后自动放到 ComfyUI 的 input 目录"
    },
    {
      "id": "horizontal_angle",
      "label": "水平角度（度）",
      "type": "number",
      "nodeId": "105",
      "field": "horizontal_angle",
      "default": 90,
      "min": 0,
      "max": 360,
      "step": 1,
      "note": "0/360 = 正面，90=左侧，180 = 背面，270=右侧"
    },
    {
      "id": "vertical_angle",
      "label": "垂直角度（度）",
      "type": "number",
      "nodeId": "105",
      "field": "vertical_angle",
      "default": 0,
      "min": -90,
      "max": 90,
      "step": 1,
      "note": "0 = 平视，正数 = 俯视，负数 = 仰视，范围：-90至90"
    },
    {
      "id": "zoom",
      "label": "缩放",
      "type": "number",
      "nodeId": "105",
      "field": "zoom",
      "default": 5,
      "min": 1,
      "max": 20,
      "step": 0.1,
      "note": "镜头缩放倍数，范围：1-20"
    },
    {
      "id": "seed",
      "label": "Seed (K采样器)",
      "type": "number",
      "nodeId": "95",
      "field": "seed",
      "default": -1,
      "randomizable": true,
      "min": -1,
      "max": 4294967295,
      "note": "-1 = 每次随机（避免 ComfyUI 命中 prompt cache 复用旧结果）"
    }
  ],
  "outputNodes": [
    { "nodeId": "62", "type": "image", "filenamePrefix": "ComfyUI" }
  ]
}