{
  "id": "Wan2.2-SmoothMix-I2V",
  "name": "Wan2.2-SmoothMix-I2V（图生视频）",
  "description": "上传图片生成 5 秒视频（默认），无声音",
  "mode": "nsfw",
  "cover": "covers/Wan2.2-SmoothMix-I2V.png",
  "coverFallback": {
    "icon": "fa-film",
    "gradient": ["#7c3aed", "#db2777"]
  },
  "workflowFile": "Wan2.2-SmoothMix-I2V.json",
  "formFields": [
    {
      "id": "start_image",
      "label": "起始图片",
      "type": "image",
      "nodeId": "141",
      "field": "image",
      "required": true,
      "accept": "image/*",
      "note": "支持 png/jpg/webp，上传后自动放到 ComfyUI 的 input 目录"
    },
    {
      "id": "positive_prompt",
      "label": "正向提示词",
      "type": "textarea",
      "nodeId": "240",
      "field": "text",
      "default": "",
      "rows": 6
    },
    {
      "id": "duration_seconds",
      "label": "视频时长（秒）",
      "type": "number",
      "nodeId": "258",
      "field": "value",
      "default": 5,
      "min": 1,
      "max": 30,
      "step": 1,
      "note": "实际帧数 = 秒数 × 16 + 1（写死 16fps）"
    }
  ],
  "outputNodes": [
    { "nodeId": "245", "type": "video", "filenamePrefix": "Video/SmoothMix" }
  ]
}
